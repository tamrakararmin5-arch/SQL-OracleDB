
CREATE TABLE Department (
    DNo NUMBER(10) PRIMARY KEY,
    Dname VARCHAR2(50),
    MgrSSN CHAR(9),
    MgrStartDate DATE
);

CREATE TABLE Employee (
    FName VARCHAR2(50),
    LName VARCHAR2(50),
    SSN CHAR(9) PRIMARY KEY,
    BDate DATE,
    Address VARCHAR2(100),
    Sex CHAR(1),
    Salary NUMBER(10,2),
    SuperSSN CHAR(9),
    DNo NUMBER(10),
    CONSTRAINT fk_dept FOREIGN KEY (DNo) REFERENCES Department(DNo)
);

