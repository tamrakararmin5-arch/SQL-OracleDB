SELECT FName, LName, Salary, Salary * 1.10 AS Increased_Salary
FROM Employee
WHERE DNo = (SELECT DNo FROM Department WHERE Dname = 'Research');

SELECT SUM(Salary), MAX(Salary), MIN(Salary), AVG(Salary)
FROM Employee
WHERE DNo = (SELECT DNo FROM Department WHERE Dname = 'Accounts');

SELECT FName, LName FROM Employee E
WHERE EXISTS (SELECT 1 FROM Department D WHERE D.DNo = 5 AND E.DNo = D.DNo);

SELECT D.Dname, COUNT(*)
FROM Employee E
JOIN Department D ON E.DNo = D.DNo
GROUP BY D.Dname
HAVING COUNT(*) >= 2;

SELECT FName, LName FROM Employee 
WHERE BDate BETWEEN TO_DATE('1990-01-01', 'YYYY-MM-DD') AND TO_DATE('1999-12-31', 'YYYY-MM-DD');

SELECT E.FName, E.LName, D.Dname
FROM Employee E
JOIN Department D ON E.DNo = D.DNo;
